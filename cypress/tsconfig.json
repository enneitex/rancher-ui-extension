{
  "compilerOptions": {
    "target": "ES2018",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2018", "DOM"],
    "esModuleInterop": true,
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true,
    "typeRoots": ["../node_modules"],
    "types": ["@types/node", "cypress"]
  },
  "include": ["**/*.ts"],
  "exclude": ["../node_modules"]
}
